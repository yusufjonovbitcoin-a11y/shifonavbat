# BotFather dan olingan token
BOT_TOKEN=

# OpenAI (skrining AI xulosasi — faqat serverda saqlanadi)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Shifokor kabineti kirish (POST /api/auth/login)
DOCTOR_LOGIN=
DOCTOR_PASSWORD=

# Web server port
PORT=3000

# CORS: frontend boshqa domen bo'lsa (masalan Vercel)
# CORS_ORIGIN=https://sizning-frontend.vercel.app

# QR / check-in uchun tashqi sayt
CHECKIN_PUBLIC_URL=https://shifonavbat.vercel.app

# Webhook rejimi uchun (ixtiyoriy)
# PUBLIC_URL=https://sizning-domen.uz
# WEBHOOK_PATH=/telegram-webhook

# Frontend build: API boshqa URL da bo'lsa (Vercel + alohida backend)
# VITE_API_BASE_URL=https://xxxx.up.railway.app

# ─── Railway (backend) ─────────────────────────────────────
# Dashboard → Variables: BOT_TOKEN, OPENAI_API_KEY, DOCTOR_LOGIN, DOCTOR_PASSWORD,
#   CORS_ORIGIN (Vercel URL), CHECKIN_PUBLIC_URL, ixtiyoriy PUBLIC_URL + WEBHOOK_PATH
# PORT o'rnatmang — Railway beradi.
# data/*.json konteynerda saqlanadi; redeployda yo'qolmasligi uchun Railway "Volume"
#   ni /app/data ga ulang yoki tashqi DB ishlating.
